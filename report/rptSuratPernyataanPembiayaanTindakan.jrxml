			<textField isStretchWithOverflow="true">
				<reportElement x="124" y="410" width="406" height="30" uuid="0039c7a6-cb5b-4472-9c2d-503b025759ec"/>
				<textElement>
					<font fontName="Tahoma" size="11" isBold="false" isItalic="false"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{alamat}]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true">
				<reportElement x="6" y="440" width="523" height="59" uuid="a76c67dd-5976-4ff8-82d0-5b3e420caad0"/>
				<textElement textAlignment="Justified">
					<font fontName="Tahoma" size="11" isBold="false"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<textFieldExpression><![CDATA["Saya telah menerima penjelasan lengkap dari pihak "+$P{namars}+" mengenai tindakan medis yang akan dilakukan, termasuk prosedur, risiko yang mungkin terjadi, dan perkiraan biaya yang diperlukan. Setelah mengerti dan memahami penjelasan tersebut, dengan ini saya menyatakan bersedia menanggung seluruh biaya tindakan medis tersebut."]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="6" y="500" width="524" height="50" uuid="6b911e15-eefb-46ad-9dd6-5cef303f6db4">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<box>
					<topPen lineWidth="0.5" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.5" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.5" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.5" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Justified" verticalAlignment="Middle">
					<font fontName="Tahoma" size="11" isBold="true"/>
					<paragraph lineSpacing="Single" leftIndent="5" rightIndent="5"/>
				</textElement>
				<text><![CDATA[Apabila saya tidak dapat menyelesaikan pembiayaan, maka saya dengan sukarela akan menjaminkan surat berharga atau barang berharga di Rumah Sakit sehingga saya dapat menyelesaikan pembiayaan Rumah Sakit.]]></text>
			</staticText>
			<staticText>
				<reportElement x="6" y="559" width="523" height="30" uuid="f453e06d-6cf8-41d9-99ef-b8ebbad68666"/>
				<textElement textAlignment="Justified">
					<font fontName="Tahoma" size="11" isBold="false"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[Saya juga menyatakan bahwa saya akan melunasi seluruh biaya tindakan sebelum pasien diperbolehkan pulang dari rumah sakit. Saya memahami bahwa jika terjadi tambahan biaya akibat komplikasi atau hal lain yang tidak terduga, saya tetap bertanggung jawab untuk melunasinya.]]></text>
			</staticText>
			<staticText>
				<reportElement x="6" y="595" width="523" height="30" uuid="8c8a27fb-cf85-4745-82ec-7d2642dca32a"/>
				<textElement textAlignment="Justified">
					<font fontName="Tahoma" size="11" isBold="false"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[Demikian pernyataan ini saya buat dengan penuh kesadaran dan tanpa paksaan dari pihak manapun agar dapat digunakan sebagaimana mestinya.]]></text>
			</staticText>
