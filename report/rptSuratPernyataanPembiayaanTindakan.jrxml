	<queryString>
		<![CDATA[select surat_pernyataan_pembiayaan_tindakan.no_surat,reg_periksa.no_rawat,pasien.no_rkm_medis,pasien.nm_pasien,reg_periksa.umurdaftar,pasien.pekerjaan,pasien.tmp_lahir,concat(pasien.alamat,', ',kelurahan.nm_kel,', ',kecamatan.nm_kec,', ',kabupaten.nm_kab,', ',propinsi.nm_prop) as alamat,reg_periksa.sttsumur,pasien.jk,pasien.tgl_lahir,surat_pernyataan_pembiayaan_tindakan.tanggal,surat_pernyataan_pembiayaan_tindakan.nama_pj,
		    surat_pernyataan_pembiayaan_tindakan.no_ktppj,surat_pernyataan_pembiayaan_tindakan.tempat_lahirpj,surat_pernyataan_pembiayaan_tindakan.lahirpj,surat_pernyataan_pembiayaan_tindakan.jkpj,surat_pernyataan_pembiayaan_tindakan.alamatpj,surat_pernyataan_pembiayaan_tindakan.hubungan,surat_pernyataan_pembiayaan_tindakan.no_telp as no_telp,surat_pernyataan_pembiayaan_tindakan.nip as nip,petugas.nama as nama
            from surat_pernyataan_pembiayaan_tindakan
            inner join reg_periksa on surat_pernyataan_pembiayaan_tindakan.no_rawat=reg_periksa.no_rawat
            inner join pasien on reg_periksa.no_rkm_medis=pasien.no_rkm_medis
            inner join petugas on surat_pernyataan_pembiayaan_tindakan.nip=petugas.nip
            inner join kelurahan on pasien.kd_kel=kelurahan.kd_kel
            inner join kecamatan on pasien.kd_kec=kecamatan.kd_kec
            inner join kabupaten on pasien.kd_kab=kabupaten.kd_kab
            inner join propinsi on pasien.kd_prop=propinsi.kd_prop
            where surat_pernyataan_pembiayaan_tindakan.no_surat='']]]>
	</queryString>
