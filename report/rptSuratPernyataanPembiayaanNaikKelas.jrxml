				<textElement textAlignment="Justified" verticalAlignment="Top">
					<font fontName="Tahoma" size="9"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<textFieldExpression><![CDATA["Atas kemauan saya sendiri / keluarga, saya memilih untuk dirawat di kelas perawatan yang lebih tinggi dari hak kelas saya, yaitu di Ruang "+ $F{ruang} + ($F{kelas} != null && !$F{kelas}.isEmpty() ? " Kelas " + $F{kelas} : "") +"."]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="20" y="277" width="15" height="13" uuid="fb3868b3-0268-48d5-a279-3cffe841c578"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Tahoma" size="9"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[3.]]></text>
			</staticText>
			<staticText>
				<reportElement x="35" y="277" width="498" height="26" uuid="0d1e2f3a-4b5c-6d7e-8f9a-0b1c2d3e4f5a"/>
				<textElement textAlignment="Justified" verticalAlignment="Top">
					<font fontName="Tahoma" size="9"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[Saya memahami dan bersedia untuk membayar selisih biaya yang timbul akibat pemilihan kelas perawatan tersebut di atas.]]></text>
			</staticText>
			<staticText>
				<reportElement x="20" y="305" width="15" height="13" uuid="15c6cc2a-0d85-47cc-afca-cf552b91cd93"/>
