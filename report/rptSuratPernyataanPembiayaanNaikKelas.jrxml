					<font fontName="Tahoma" size="9"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[c.]]></text>
			</staticText>
			<textField isStretchWithOverflow="true">
				<reportElement x="50" y="432" width="483" height="13" uuid="1c2d3e4f-5a6b-7c8d-9e0f-1a2b3c4d5e6f"/>
				<textElement textAlignment="Justified" verticalAlignment="Top">
					<font fontName="Tahoma" size="9"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<textFieldExpression><![CDATA["Telah memahami dan bersedia mentaati segala peraturan serta tata tertib yang berlaku di "+$P{namars}]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="35" y="447" width="15" height="13" uuid="2d3e4f5a-6b7c-8d9e-0f1a-2b3c4d5e6f7a"/>
