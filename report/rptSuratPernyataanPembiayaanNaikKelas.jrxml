				<text><![CDATA[1.]]></text>
			</staticText>
			<textField isStretchWithOverflow="true">
				<reportElement x="35" y="234" width="498" height="13" uuid="8b9c0d1e-2f3a-4b5c-6d7e-8f9a0b1c2d3e"/>
				<textElement textAlignment="Justified" verticalAlignment="Top">
					<font fontName="Tahoma" size="9"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<textFieldExpression><![CDATA["Saya telah mendapatkan penjelasan mengenai hak pasien untuk memilih kelas perawatan sesuai dengan hak kelasnya yaitu: Kelas "+
($F{hak_kelas} == null || $F{hak_kelas}.isEmpty() || $F{hak_kelas}.equals("-") ? "Tidak Ada" : $F{hak_kelas}) +"."]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="20" y="249" width="15" height="13" uuid="b20617f7-1ac1-4286-9cf9-0242961b8814"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Tahoma" size="9"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[2.]]></text>
			</staticText>
			<textField isStretchWithOverflow="true">
