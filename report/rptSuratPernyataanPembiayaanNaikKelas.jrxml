					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[Dengan ini menyatakan dengan sesungguhnya bahwa:]]></text>
			</staticText>
			<staticText>
				<reportElement x="20" y="234" width="15" height="13" uuid="c72900de-7947-4366-9815-141b252114f4"/>
