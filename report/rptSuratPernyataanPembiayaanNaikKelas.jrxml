				<reportElement x="50" y="350" width="483" height="26" uuid="7e8f9a0b-1c2d-3e4f-5a6b-7c8d9e0f1a2b"/>
				<textElement textAlignment="Justified" verticalAlignment="Top">
					<font fontName="Tahoma" size="9"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[Setuju dan memberi izin kepada dokter dan tenaga kesehatan yang bertugas untuk merawat dan memberikan tindakan medis yang diperlukan kepada pasien tersebut di atas sesuai standar profesi.]]></text>
			</staticText>
			<staticText>
				<reportElement x="35" y="378" width="15" height="13" uuid="8f9a0b1c-2d3e-4f5a-6b7c-8d9e0f1a2b3c"/>
