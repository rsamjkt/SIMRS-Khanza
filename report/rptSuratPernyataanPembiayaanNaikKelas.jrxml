				<textElement textAlignment="Justified" verticalAlignment="Top">
					<font fontName="Tahoma" size="9"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<textFieldExpression><![CDATA["Informasi keluarga terdekat yang dapat dihubungi: " + ($F{nama_alamat_keluarga_terdekat} == null || $F{nama_alamat_keluarga_terdekat}.isEmpty() ? "[N/A]" : $F{nama_alamat_keluarga_terdekat}) +"."]]></textFieldExpression>
			</textField>
