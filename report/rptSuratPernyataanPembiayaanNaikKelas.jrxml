				<textFieldExpression><![CDATA[($F{tgl_lahir} == null ? "" : new SimpleDateFormat("dd-MM-yyyy", new Locale("id","ID")).format($F{tgl_lahir})) + " / " + ($F{umurdaftar} == null ? "" : $F{umurdaftar}) + " " + ($F{sttsumur} == null ? "" : $F{sttsumur})]]></textFieldExpression>
			</textField>
			<staticText>
