				</textElement>
				<text><![CDATA[d.]]></text>
			</staticText>
			<textField isStretchWithOverflow="true">
				<reportElement x="50" y="447" width="483" height="26" uuid="3e4f5a6b-7c8d-9e0f-1a2b-3c4d5e6f7a8b"/>
				<textElement textAlignment="Justified" verticalAlignment="Top">
					<font fontName="Tahoma" size="9"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<textFieldExpression><![CDATA["Memberi kuasa kepada Dokter dan "+$P{namars}+" untuk memberikan informasi/keterangan medis yang diperlukan oleh pihak penjamin pembiayaan perawatan pasien tersebut di atas."]]></textFieldExpression>
			</textField>
			<staticText>
