				<textElement textAlignment="Justified" verticalAlignment="Top">
					<font fontName="Tahoma" size="9"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<textFieldExpression><![CDATA["Metode pembayaran yang akan digunakan adalah secara " + $F{bayar_secara} + "."]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="20" y="320" width="15" height="13" uuid="2f3a4b5c-6d7e-8f9a-0b1c-2d3e4f5a6b7c"/>
