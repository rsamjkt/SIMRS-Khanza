			</staticText>
			<textField isStretchWithOverflow="true">
				<reportElement x="50" y="378" width="483" height="52" uuid="9a0b1c2d-3e4f-5a6b-7c8d-9e0f1a2b3c4d"/>
				<textElement textAlignment="Justified" verticalAlignment="Top">
					<font fontName="Tahoma" size="9"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<textFieldExpression><![CDATA["Dengan ini menyatakan dengan sesungguhnya bahwa seluruh pembiayaan pelayanan di "+$P{namars}+", termasuk selisih biaya akibat pemilihan kelas perawatan di atas hak kelas, akan saya bayarkan sesuai dengan ketentuan yang berlaku. Saya bersedia melengkapi berkas administrasi yang diperlukan. Apabila penjamin yang digunakan memerlukan verifikasi dan kelengkapan berkas dalam batas waktu tertentu (misal: 3x24 jam untuk BPJS), dan saya tidak dapat memenuhinya, maka saya bersedia membayar seluruh biaya perawatan sebagai pasien umum/pribadi."]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="35" y="432" width="15" height="13" uuid="0b1c2d3e-4f5a-6b7c-8d9e-0f1a2b3c4d5e"/>
