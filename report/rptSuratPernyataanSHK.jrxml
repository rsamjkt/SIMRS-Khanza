	<queryString>
		<![CDATA[/* Query ini HANYA untuk preview di Jaspersoft Studio & mendefinisikan struktur field. */
/* Query aktual ditentukan & dijalankan di Kode Java. */
SELECT
    s.no_pernyataan,
    s.no_rawat,
    rp.no_rkm_medis,
    p.nm_pasien AS nama_bayi,
    p.jk,
    p.tgl_lahir AS tgl_lahir,
    COALESCE(pb.jam_lahir, '00:00:00') AS jam_lahir,
    s.nama_ibu,
    s.nama_ayah,
    s.alamat_orangtua,
    s.no_telp_orangtua,
    s.tgl_pernyataan,
    s.tgl_pengambilan_sample,
    s.jam_pengambilan_sample,
    s.tempat_pengambilan,
    s.nip_petugas,
    pt.nama AS nama_petugas,
    p.jk
FROM
    surat_pernyataan_shk s
INNER JOIN reg_periksa rp ON
    s.no_rawat = rp.no_rawat
INNER JOIN pasien p ON
    rp.no_rkm_medis = p.no_rkm_medis
LEFT JOIN pasien_bayi pb ON
    p.no_rkm_medis = pb.no_rkm_medis
INNER JOIN petugas pt ON
    s.nip_petugas = pt.nip
WHERE
    s.no_pernyataan = 'SPSHK202408210001' /* Ganti dengan no_pernyataan valid untuk preview */
LIMIT 1]]>
	</queryString>
